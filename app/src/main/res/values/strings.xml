<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">PDA消息兜底</string>
    <string name="foreground_title">消息监控运行中</string>

    <string name="permission_title">权限配置</string>
    <string name="permission_intro">请尽量在本页用按钮跳转设置。仅「通知使用权」为必须项；找不到电池/自启动菜单时可勾选跳过。</string>

    <string name="permission_notification_title">1. 通知使用权（必须）</string>
    <string name="permission_notification_desc">用于读取 Hi护士 等 APP 的系统通知，是兜底提醒的核心权限。点下方按钮后在系统列表中开启「PDA消息兜底」。</string>
    <string name="permission_battery_title">2. 忽略电池优化（建议）</string>
    <string name="permission_battery_desc">防止 PDA 省电策略杀死后台。若点按钮无反应或本机无此项，可勾选跳过。</string>
    <string name="permission_autostart_title">3. 自启动 / 后台白名单（建议）</string>
    <string name="permission_autostart_desc">点下方按钮尝试打开厂商自启动页。若本机没有该菜单，请将本 APP 在「最近任务」中锁定，并勾选「已完成/跳过」。</string>

