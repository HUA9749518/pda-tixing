<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/main_title"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_package"
        android:textColor="@color/text_primary" />

    <EditText
        android:id="@+id/edit_package"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_package"
        android:inputType="text"
        android:singleLine="true" />

    <CheckBox
        android:id="@+id/check_boot_start"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/check_boot_start"
        android:textColor="@color/text_primary" />

    <CheckBox
        android:id="@+id/check_alert_enabled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/check_alert_enabled"
        android:textColor="@color/text_primary" />

    <CheckBox
        android:id="@+id/check_sound"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/check_sound"
        android:textColor="@color/text_primary" />

    <CheckBox
        android:id="@+id/check_vibrate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/check_vibrate"
        android:textColor="@color/text_primary" />

    <CheckBox
        android:id="@+id/check_wake_screen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/check_wake_screen"
        android:textColor="@color/text_primary" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_stay"
        android:textColor="@color/text_primary" />

    <Spinner
        android:id="@+id/spinner_stay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/status_keepalive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/status_listener"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="4dp"
        android:textColor="@color/text_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_save" />

        <Button
            android:id="@+id/btn_test"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_test" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_permissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_permissions" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/label_history"
        android:textColor="@color/text_primary"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/list_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/page_bg"
        android:cacheColorHint="@color/page_bg"
        android:divider="#BDBDBD"
        android:dividerHeight="1dp"
        android:fastScrollEnabled="false"
        android:scrollingCache="false"
        android:smoothScrollbar="false" />

    <Button
        android:id="@+id/btn_clear_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_clear_history" />

</LinearLayout>
