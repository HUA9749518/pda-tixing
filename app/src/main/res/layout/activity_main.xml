<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_package" />

        <EditText
            android:id="@+id/edit_package"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_package"
            android:inputType="text"
            android:singleLine="true" />

        <CheckBox
            android:id="@+id/check_alert_enabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check_alert_enabled" />

        <CheckBox
            android:id="@+id/check_sound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check_sound" />

        <CheckBox
            android:id="@+id/check_vibrate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check_vibrate" />

        <CheckBox
            android:id="@+id/check_wake_screen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check_wake_screen" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_stay" />

        <Spinner
            android:id="@+id/spinner_stay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/status_keepalive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/status_listener"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_save" />

            <Button
                android:id="@+id/btn_test"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_test" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_permissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_permissions" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_history"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="@string/history_empty" />

        <Button
            android:id="@+id/btn_clear_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_clear_history" />

    </LinearLayout>
</ScrollView>
